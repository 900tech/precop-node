FLORESTA_RPC_PASS="rpc_password_change_me"
FLORESTA_BINARY_PATH="./bin/florestad"
NODE_CONFIG_PATH="./node-config/floresta.toml"

# 💰 CONSENSUS (The Queen's Seal)
